# Calino — example environment file
#
# Copy this file to `.env.local` and adjust the values for your deployment.
# `.env.local` is git-ignored and is the standard Vite location for secrets
# and per-build overrides.

# Public URL where Calino is served. Used for SEO meta tags, Open Graph
# cards, canonical link, and the structured-data JSON-LD block in
# index.html. Must NOT include a trailing slash.
#
# Example: VITE_SITE_URL=https://calendar.example.com
VITE_SITE_URL=https://calino.io

:8080 {
	# ── Static files ──────────────────────────────────────────────
	root * /srv

	# SPA fallback — serve index.html for any path that doesn't match a file
	try_files {path} /index.html

	file_server

	# ── Request body limit ────────────────────────────────────────
	# Static site — no uploads. Tight limit shrinks attack surface.
	request_body {
		max_size 1kb
	}

	# ── Gzip compression ─────────────────────────────────────────
	encode gzip {
		min_length 256
	}

	# ── Security headers ─────────────────────────────────────────
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		-Server
	}

	# ── Static assets — long cache, immutable ────────────────────
	@assets path /assets/*
	header @assets Cache-Control "public, immutable"

	# ── Service worker — no cache ────────────────────────────────
	@sw path /sw.js
	header @sw Cache-Control "no-store, no-cache, must-revalidate"
	header @sw Service-Worker-Allowed "/"

	# ── Logging ──────────────────────────────────────────────────
	log {
		output stdout
		format console
	}
}

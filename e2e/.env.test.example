# E2E test config — copy to .env.test (gitignored) and fill in.
# These vars are REQUIRED for the live-CalDAV smoke tests:
#   - "add CalDAV account flow: form, discovery, success"
#   - "settings persist across reload (localStorage round-trip)"
# Without them, those tests are skipped — the other 8 still run.
#
# All three vars must be set; if any is missing, the live tests skip.
CALINO_TEST_CALDAV_URL=
CALINO_TEST_CALDAV_USER=
CALINO_TEST_CALDAV_PASS=